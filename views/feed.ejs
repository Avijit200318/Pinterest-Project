<% include ./partials/header.ejs %>
    <div class="w-full min-h-screen px-2 pt-4 pb-20 md:px-4 md:pt-12 lg:px-10 lg:py-8 xl:px-10 xl:py-8">
        <div class="cards flex flex-wrap justify-center px-2 gap-2 md:gap-6  md:px-8 xl:px-10 2xl:px-20 2xl:justify-start">
            <% posts.forEach(function(ele) { %>
                <div class=" card w-40 sm:w-48">
                    <div class="w-full h-60 bg-sky-200 rounded-lg overflow-hidden sm:h-64">
                        <a href="/show/post/<%= ele._id%>">
                        <img src="/images/uploads/<%= ele.image %>" class="w-full h-full object-cover" alt="">
                    </a>
                    </div>
                    <a href="/show/post/<%= ele._id%>" class="mt-2 text-sm">
                        <%=ele.title %>
                    </a>
                    <h6 class="text-xs font-semibold opacity-50">@<%= ele.user.username %></h6>
                </div>
                <% }) %>
                
        </div>
    </div>
    <% include ./partials/footer.ejs %>